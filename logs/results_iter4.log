    rev_stab['max_energy_drift'] = float(np.nanmax(rel_energy_drift))
    pos_T5 = pos_pred[-1]
    vel_T5 = vel_pred[-1]
    t_eval_back = torch.tensor([0.0, 5.0], device=device)
    with torch.no_grad():
