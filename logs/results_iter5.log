    fig.savefig(plot1_path, dpi=300)
    plt.close(fig)
    fig, ax = plt.subplots(figsize=(8, 6))
    time_steps = np.linspace(0, 5.0, 11)
    for i in range(n_traj):
        ax.plot(time_steps, H_vals[:, i] - H_vals[0, i], marker='o', label='Sim ' + str(i+1))
    ax.set_xlabel('Time (T)')
