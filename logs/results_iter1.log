**Code Explanation:**

This script evaluates the long-term rollout performance of the trained Symplectic Neural ODE, RK4 Neural ODE, and Baseline MLP models. It loads the test set (the last 20 simulations from the generated trajectories) and performs autonomous integration from $t=0$ to $t=5.0$ using the learned vector fields. 

The evaluation is performed across different numbers of particles ($N=25, 40, 50$) to test the generalization capabilities of the GNN-based ODE models to varying interaction topologies. For each model and $N$, the script computes the Mean Squared Error (MSE) for positions and velocities at the final time step ($t=5.0$). It also calculates the energy drift rate ($\Delta E / \Delta t$) and the Mean Absolute Energy Error (MAE) over the full trajectory to assess how well each integration scheme conserves the Hamiltonian. The MLP is only evaluated for $N=50$ since its architecture expects a fixed input dimension.

All computed metrics, energy histories, and predicted trajectories are saved to `data/rollout_results.pt` for subsequent visualization. Note that the positions, velocities, and energies are evaluated in the normalized dimensionless units established during data preparation.

**Python Code:**

```python
import sys
import os
sys.path.insert(0, os.path.abspath("codebase"))
import torch
import torch.nn as nn
from step_1 import NBodyDataset
from step_2 import GNNInteractionNetwork
from step_3 import SymplecticVerlet, RK4, compute_energy
from step_4 import BaselineMLP

def evaluate_rollout():
    """
    Evaluates the long-term rollout of the trained models from t=0 to t=5.0.
    Computes MSE on final positions and velocities, and energy conservation metrics.
    Evaluates on varying number of particles N to test generalization.
    """
    device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')

    # Load normalized trajectory data
    data = torch.load('data/trajectories.pt', weights_only=True)
    pos_all = data['pos']
    vel_all = data['vel']
    t_eval = data['t'].to(device)

    # Test set is the last 20 simulations
    pos_test = pos_all[80:].to(device)
    vel_test = vel_all[80:].to(device)

    # Load trained models
    gnn_symp = GNNInteractionNetwork(hidden_dim=64).to(device)
    gnn_symp.load_state_dict(torch.load('data/gnn_symplectic.pt', map_location=device, weights_only=True))
    gnn_symp.eval()

    gnn_rk4 = GNNInteractionNetwork(hidden_dim=64).to(device)
    gnn_rk4.load_state_dict(torch.load('data/gnn_rk4.pt', map_location=device, weights_only=True))
    gnn_rk4.eval()

    mlp = BaselineMLP(n_particles=50).to(device)
    mlp.load_state_dict(torch.load('data/model_mlp.pt', map_location=device, weights_only=True))
    mlp.eval()

    # Instantiate ODE solvers
    solver_symp = SymplecticVerlet(gnn_symp, dt=0.01)
    solver_rk4 = RK4(gnn_rk4, dt=0.01)

    results = {}

    for N in [25, 40, 50]:
        print(f"\n========================================")
        print(f"Evaluating Long-Term Rollout for N={N}")
        print(f"========================================")
        
        p_test_N = pos_test[:, :, :N, :]
        v_test_N = vel_test[:, :, :N, :]
        
        p_init = p_test_N[:, 0]
        v_init = v_test_N[:, 0]
        p_target = p_test_N[:, -1]
        v_target = v_test_N[:, -1]
        
        # Ground Truth Energy Analysis
        energies_gt = []
        for i in range(11):
            e = compute_energy(p_test_N[:, i], v_test_N[:, i], eps=0.01)
            energies_gt.append(e)
        energies_gt = torch.stack(energies_gt, dim=1)
        e_drift_rate_gt = torch.abs(energies_gt[:, -1] - energies_gt[:, 0]).mean().item() / 5.0
        e_mae_gt = torch.abs(energies_gt - energies_gt[:, 0:1]).mean().item()
        
        print(f"Ground Truth - E Drift Rate: {e_drift_rate_gt:.6e}, E MAE: {e_mae_gt:.6e}")
        
        # Symplectic Neural ODE Evaluation
        with torch.no_grad():
            p_pred_symp, v_pred_symp = solver_symp.integrate_trajectory(p_init, v_init, t_eval)
            p_pred_symp = p_pred_symp.permute(1, 0, 2, 3)
            v_pred_symp = v_pred_symp.permute(1, 0, 2, 3)
            
            mse_pos_symp = nn.functional.mse_loss(p_pred_symp[:, -1], p_target).item()
            mse_vel_symp = nn.functional.mse_loss(v_pred_symp[:, -1], v_target).item()
            
            energies_symp = []
            for i in range(11):
                e = compute_energy(p_pred_symp[:, i], v_pred_symp[:, i], eps=gnn_symp.epsilon.item())
                energies_symp.append(e)
            energies_symp = torch.stack(energies_symp, dim=1)
            
            e_drift_rate_symp = torch.abs(energies_symp[:, -1] - energies_symp[:, 0]).mean().item() / 5.0
            e_mae_symp = torch.abs(energies_symp - energies_symp[:, 0:1]).mean().item()
            
        # RK4 Neural ODE Evaluation
        with torch.no_grad():
            p_pred_rk4, v_pred_rk4 = solver_rk4.integrate_trajectory(p_init, v_init, t_eval)
            p_pred_rk4 = p_pred_rk4.permute(1, 0, 2, 3)
            v_pred_rk4 = v_pred_rk4.permute(1, 0, 2, 3)
            
            mse_pos_rk4 = nn.functional.mse_loss(p_pred_rk4[:, -1], p_target).item()
            mse_vel_rk4 = nn.functional.mse_loss(v_pred_rk4[:, -1], v_target).item()
            
            energies_rk4 = []
            for i in range(11):
                e = compute_energy(p_pred_rk4[:, i], v_pred_rk4[:, i], eps=gnn_rk4.epsilon.item())
                energies_rk4.append(e)
            energies_rk4 = torch.stack(energies_rk4, dim=1)
            
            e_drift_rate_rk4 = torch.abs(energies_rk4[:, -1] - energies_rk4[:, 0]).mean().item() / 5.0
            e_mae_rk4 = torch.abs(energies_rk4 - energies_rk4[:, 0:1]).mean().item()
            
        # Baseline MLP Evaluation (only valid for N=50 due to fixed input dimension)
        if N == 50:
            with torch.no_grad():
                p_pred_mlp, v_pred_mlp = mlp(p_init, v_init)
                mse_pos_mlp = nn.functional.mse_loss(p_pred_mlp, p_target).item()
                mse_vel_mlp = nn.functional.mse_loss(v_pred_mlp, v_target).item()
                
                e_init_mlp = compute_energy(p_init, v_init, eps=0.01)
                e_final_mlp = compute_energy(p_pred_mlp, v_pred_mlp, eps=0.01)
                e_drift_rate_mlp = torch.abs(e_final_mlp - e_init_mlp).mean().item() / 5.0
                e_mae_mlp = torch.abs(e_final_mlp - e_init_mlp).mean().item()
        else:
            mse_pos_mlp = None
            mse_vel_mlp = None
            e_drift_rate_mlp = None
            e_mae_mlp = None
            
        # Store results
        results[N] = {
            'symp': {
                'mse_pos': mse_pos_symp, 'mse_vel': mse_vel_symp, 
                'e_drift_rate': e_drift_rate_symp, 'e_mae': e_mae_symp, 
                'traj_p': p_pred_symp.cpu(), 'traj_v': v_pred_symp.cpu(), 'energies': energies_symp.cpu()
            },
            'rk4': {
                'mse_pos': mse_pos_rk4, 'mse_vel': mse_vel_rk4, 
                'e_drift_rate': e_drift_rate_rk4, 'e_mae': e_mae_rk4, 
                'traj_p': p_pred_rk4.cpu(), 'traj_v': v_pred_rk4.cpu(), 'energies': energies_rk4.cpu()
            },
            'mlp': {
                'mse_pos': mse_pos_mlp, 'mse_vel': mse_vel_mlp, 
                'e_drift_rate': e_drift_rate_mlp, 'e_mae': e_mae_mlp
            },
            'gt': {
                'traj_p': p_test_N.cpu(), 'traj_v': v_test_N.cpu(), 'energies': energies_gt.cpu()
            }
        }
        
        print(f"Symplectic - MSE Pos: {mse_pos_symp:.6e}, MSE Vel: {mse_vel_symp:.6e}, E Drift Rate: {e_drift_rate_symp:.6e}, E MAE: {e_mae_symp:.6e}")
        print(f"RK4        - MSE Pos: {mse_pos_rk4:.6e}, MSE Vel: {mse_vel_rk4:.6e}, E Drift Rate: {e_drift_rate_rk4:.6e}, E MAE: {e_mae_rk4:.6e}")
        if N == 50:
            print(f"MLP        - MSE Pos: {mse_pos_mlp:.6e}, MSE Vel: {mse_vel_mlp:.6e}, E Drift Rate: {e_drift_rate_mlp:.6e}, E MAE: {e_mae_mlp:.6e}")

    # Save all metrics and trajectories for visualization
    torch.save(results, 'data/rollout_results.pt')
    print("\nRollout results saved to data/rollout_results.pt")

if __name__ == '__main__':
    evaluate_rollout()
```

