engineer (to main_cmbagent_chat):

**Code Explanation:**

The script loads the N-body dataset and metadata, handling the shape of `ic_final.npy` robustly by reshaping and filtering based on the `time` field to extract the initial conditions (t=0) and ground-truth final states (t=5.0). 
A vectorized leapfrog integrator is implemented in PyTorch (using `float64` for numerical precision) to re-simulate the trajectories and generate 10 intermediate snapshots (plus the initial and final states, totaling 11 snapshots per simulation). The re-generated final states are compared against the ground truth to verify consistency, and the maximum errors are printed.
Positions and velocities are normalized using their global initial root-mean-square (RMS) values, which serve as proxies for the virial radius and velocity dispersion. The augmented dataset (normalized and unnormalized trajectories, along with normalization constants and time steps) is saved to `data/trajectories.pt`.
Finally, a PyTorch `Dataset` class (`NBodyDataset`) is implemented to load the saved trajectories, supporting dynamic particle masking for N-sensitivity analysis, and a quick test of the DataLoader is performed.

**Python Code:**

```python
import numpy as np
import torch
from torch.utils.data import Dataset, DataLoader
import os

def compute_accelerations(pos, eps=0.01):
    """
    Computes gravitational accelerations for a batch of N-body simulations.
    
    Args:
        pos (torch.Tensor): Positions of shape (N_sim, N_part, 3).
        eps (float): Gravitational softening parameter.
        
    Returns:
        torch.Tensor: Accelerations of shape (N_sim, N_part, 3).
    """
    # dx[sim, i, j] = pos[sim, j] - pos[sim, i]
    dx = pos.unsqueeze(1) - pos.unsqueeze(2)
    r2 = torch.sum(dx**2, dim=-1)
    r3 = (r2 + eps**2)**1.5
    a = dx / r3.unsqueeze(-1)
    return torch.sum(a, dim=2)

def leapfrog_integrate(pos, vel, dt=0.01, steps=500, save_interval=50, eps=0.01):
    """
    Integrates the N-body system using the leapfrog (kick-drift-kick) scheme.
    
    Args:
        pos (torch.Tensor): Initial positions of shape (N_sim, N_part, 3).
        vel (torch.Tensor): Initial velocities of shape (N_sim, N_part, 3).
        dt (float): Integration timestep.
        steps (int): Total number of integration steps.
        save_interval (int): Number of steps between saved snapshots.
        eps (float): Gravitational softening parameter.
        
    Returns:
        Tuple[torch.Tensor, torch.Tensor]: Trajectories of positions and velocities,
                                           each of shape (N_sim, num_snapshots, N_part, 3).
    """
    trajectories_pos = [pos.clone()]
    trajectories_vel = [vel.clone()]
    
    a = compute_accelerations(pos, eps)
    
    for step in range(1, steps + 1):
        vel_half = vel + 0.5 * dt * a
        pos = pos + dt * vel_half
        a = compute_accelerations(pos, eps)
        vel = vel_half + 0.5 * dt * a
        
        if step % save_interval == 0:
            trajectories_pos.append(pos.clone())
            trajectories_vel.append(vel.clone())
            
    return torch.stack(trajectories_pos, dim=1), torch.stack(trajectories_vel, dim=1)

class NBodyDataset(Dataset):
    """
    Dataset for N-body trajectories with support for particle masking.
    """
    def __init__(self, data_path="data/trajectories.pt", split="train", n_particles=50):
        """
        Args:
            data_path (str): Path to the saved trajectories.
            split (str): 'train' (first 80 simulations) or 'test' (last 20 simulations).
            n_particles (int): Number of particles to keep (for N-sensitivity analysis).
        """
        data = torch.load(data_path, weights_only=True)
        self.pos = data['pos']
        self.vel = data['vel']
        self.t = data['t']
        
        if split == "train":
            self.pos = self.pos[:80]
            self.vel = self.vel[:80]
        elif split == "test":
            self.pos = self.pos[80:]
            self.vel = self.vel[80:]
        else:
            raise ValueError("split must be 'train' or 'test'")
            
        self.n_particles = n_particles
        
    def __len__(self):
        return len(self.pos)
        
    def __getitem__(self, idx):
        p = self.pos[idx, :, :self.n_particles, :]
        v = self.vel[idx, :, :self.n_particles, :]
        return p, v

if __name__ == '__main__':
    # Define paths
    data_path = '/home/node/work/projects/nbody_emulator/data/ic_final.npy'
    metadata_path = '/home/node/work/projects/nbody_emulator/data/sim_metadata.npy'
    
    print("Loading dataset...")
    data = np.load(data_path)
    metadata = np.load(metadata_path)
    
    # Handle potential shapes of ic_final.npy robustly
    data_flat = data.reshape(-1, 50, 13)
    
    # Extract Initial Conditions (t=0) and Final States (t>0) based on the time field (index 12)
    ic_data = data_flat[data_flat[:, 0, 12] == 0]
    final_data = data_flat[data_flat[:, 0, 12] > 0]
    
    # Use float64 for accurate integration to minimize numerical divergence from ground truth
    pos_ic = torch.tensor(ic_data[..., 0:3], dtype=torch.float64)
    vel_ic = torch.tensor(ic_data[..., 3:6], dtype=torch.float64)
    
    pos_final_gt = torch.tensor(final_data[..., 0:3], dtype=torch.float64)
    vel_final_gt = torch.tensor(final_data[..., 3:6], dtype=torch.float64)
    
    print(f"Extracted {len(pos_ic)} initial conditions and {len(pos_final_gt)} final states.")
    
    print("\nMetadata summary:")
    print(f"  Initial KE mean: {metadata[:, 2].mean():.4f}")
    print(f"  Initial PE mean: {metadata[:, 3].mean():.4f}")
    print(f"  Final KE mean: {metadata[:, 4].mean():.4f}")
    print(f"  Final PE mean: {metadata[:, 5].mean():.4f}")
    print(f"  Energy error mean: {metadata[:, 6].mean():.6e}")
    
    print("\nRunning leapfrog integrator to generate intermediate snapshots...")
    pos_traj, vel_traj = leapfrog_integrate(pos_ic, vel_ic, dt=0.01, steps=500, save_interval=50, eps=0.01)
    
    # Verify consistency against ground truth
    pos_final_pred = pos_traj[:, -1]
    vel_final_pred = vel_traj[:, -1]
    
    pos_error = torch.max(torch.abs(pos_final_pred - pos_final_gt)).item()
    vel_error = torch.max(torch.abs(vel_final_pred - vel_final_gt)).item()
    
    print(f"\nConsistency check against ground truth:")
    print(f"  Max position error at t=5.0: {pos_error:.6e}")
    print(f"  Max velocity error at t=5.0: {vel_error:.6e}")
    
    # Convert back to float32 for saving and ML training
    pos_traj = pos_traj.to(torch.float32)
    vel_traj = vel_traj.to(torch.float32)
    pos_ic_f32 = pos_ic.to(torch.float32)
    vel_ic_f32 = vel_ic.to(torch.float32)
    
    # Compute normalization constants (RMS as proxy for virial radius and velocity dispersion)
    pos_rms = torch.sqrt(torch.mean(pos_ic_f32**2)).item()
    vel_rms = torch.sqrt(torch.mean(vel_ic_f32**2)).item()
    
    print("\nNormalization statistics:")
    print(f"  Position RMS (Virial Radius proxy): {pos_rms:.4f}")
    print(f"  Velocity RMS (Velocity Dispersion proxy): {vel_rms:.4f}")
    
    pos_traj_norm = pos_traj / pos_rms
    vel_traj_norm = vel_traj / vel_rms
    
    print(f"  Normalized position std: {pos_traj_norm[:, 0].std().item():.4f}")
    print(f"  Normalized velocity std: {vel_traj_norm[:, 0].std().item():.4f}")
    
    # Save augmented dataset
    os.makedirs("data", exist_ok=True)
    save_path = "data/trajectories.pt"
    torch.save({
        'pos': pos_traj_norm,
        'vel': vel_traj_norm,
        'pos_unnorm': pos_traj,
        'vel_unnorm': vel_traj,
        'pos_rms': pos_rms,
        'vel_rms': vel_rms,
        't': torch.linspace(0, 5.0, 11)
    }, save_path)
    print(f"\nAugmented dataset saved to {save_path}")
    
    # Test DataLoader
    dataset = NBodyDataset(data_path=save_path, split="train", n_particles=25)
    loader = DataLoader(dataset, batch_size=16, shuffle=True)
    p_batch, v_batch = next(iter(loader))
    print(f"\nDataLoader test (N=25):")
    print(f"  Batch position shape: {p_batch.shape}")
    print(f"  Batch velocity shape: {v_batch.shape}")
```

